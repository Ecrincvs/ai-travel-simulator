# =============================================================================
# AI Travel Simulator — environment configuration (EXAMPLE)
#
# Copy this file to `.env.local` and fill in what you need.
# `.env.local` is git-ignored (see .gitignore `*.local`) — put secrets there.
# NEVER commit real API keys.
# =============================================================================

# ---- Client-side (bundled into the browser build; VITE_ prefix REQUIRED) ----
# WARNING: every VITE_* value is shipped to the browser in plain text.
# DO NOT put API keys in a VITE_* variable — they would be publicly readable.

# Turn real AI planning on/off. Leave "false" to use the built-in mock planner.
VITE_AI_ENABLED=false

# URL of YOUR backend proxy that generates a plan and returns it as a TripPlan
# JSON. The proxy is where the provider API key lives — the browser never calls
# Claude/OpenAI directly. Leave empty to stay on the mock.
VITE_AI_ENDPOINT=

# How long (ms) to wait for the AI proxy before falling back to the mock.
VITE_AI_TIMEOUT_MS=12000

# ---- Server-side (used ONLY by the backend proxy; NO VITE_ prefix) ----
# Examples for the proxy you deploy later. These are NOT read by the browser
# app and NOT bundled. Keep real keys in your host's secret manager.

# Which provider the proxy should call: "anthropic" or "openai".
AI_PROVIDER=anthropic

# Anthropic (Claude) — https://platform.claude.com
ANTHROPIC_API_KEY=
# Default to the latest, most capable Claude model.
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI (alternative provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
